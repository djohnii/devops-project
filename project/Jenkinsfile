pipeline {
    agent {
        label "agent-1"
    } 
    environment {
        registry = "alwx1753/devops-project"
        registryCredential = 'dockerhub'
    }
    stages {
        stage('test'){
            steps{
                script{
                    sh 'uname -a'
                    dir('project/docker'){
                        sh 'ls'
                        sh 'pwd'
                        docker.build registry + ":$BUILD_NUMBER"
                    }
                }
            }
        }
    }
}
