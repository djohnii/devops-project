pipeline {
    agent {
        label "agent-1"
    } 
    environment {
        registry = "alwx1753/devops-project"
        registryCredential = 'dockerhub'
        dockerImage = ''
    }
    stages {
        stage('build docker image'){
            steps{
                script{
                    dir('project/docker'){
                        docker.build registry + ":$BUILD_NUMBER"
                    }
                }
            }
        }
        stage('deploy image') {
            steps{
                script{
                    docker.withRegestry( '', registryCredential ) {
                        dockerImage.push()
                    }
                }
            }
        }
    }
}
